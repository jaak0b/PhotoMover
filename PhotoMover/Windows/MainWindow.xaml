<Window x:Class="PhotoMover.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:photoMover="clr-namespace:PhotoMover"
        mc:Ignorable="d"
        Title="MainWindow" Name="MW" Height="450" Width="800" Initialized="MainWindow_OnInitialized">
    <Window.Resources>
        <photoMover:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <TabControl>
        <TabItem Header="Home">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Button Content="Start" Grid.Row="0" Margin="5" Padding="5" Name="ProcessFilesButton"
                        Click="ButtonBase_OnClick">
                </Button>
                <ProgressBar Grid.Row="1" Name="LoadFilesProgressBar"
                             Visibility="{Binding ElementName=MW, Path=ShowLoadFilesProgress,Converter={StaticResource BoolToVisibilityConverter} }"
                             IsIndeterminate="True" />
                <ProgressBar Grid.Row="2" Name="ProcessFilesProgressBar"
                             Visibility="{Binding ElementName=MW, Path=ProcessFilesProgress,Converter={StaticResource BoolToVisibilityConverter} }"
                             IsIndeterminate="False" />
                <ProgressBar Grid.Row="3" Name="MoveFilesProgressBar"
                             Visibility="{Binding ElementName=MW, Path=MoveFilesProgress,Converter={StaticResource BoolToVisibilityConverter} }"
                             IsIndeterminate="False" />
                <DataGrid Grid.Row="4" Name="TasksDataGrid" Margin="5" Padding="5"
                          Visibility="{Binding ElementName=MW, Path=ShowOverview,Converter={StaticResource BoolToVisibilityConverter} }">
                </DataGrid>
            </Grid>
        </TabItem>
        <TabItem Header="Settings" Name="SettingsTabItem" />
    </TabControl>
</Window>